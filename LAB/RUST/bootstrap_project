#!/usr/bin/env bash
set -e

PROJECT=${1:-deepsea_ml}

echo "Creating project $PROJECT"

mkdir -p $PROJECT
cd $PROJECT

############################################
# directories
############################################

mkdir -p rust-core/src/{io,dataset,cv,experiment,parallel,gpu}
mkdir -p rust-core/tests
mkdir -p python/deepsea_ml/{storage,experiments,cv,dataset}
mkdir -p tests/python
mkdir -p scripts
mkdir -p configs
mkdir -p .github/workflows

############################################
# Rust Cargo
############################################

cat > rust-core/Cargo.toml <<'EOF'
[package]
name = "deepsea_core"
version = "0.1.0"
edition = "2021"

[lib]
name = "deepsea_core"
crate-type = ["cdylib"]

[dependencies]
pyo3 = { version="0.20", features=["extension-module"] }
maturin = "1"

tokio = { version="1", features=["full"] }
rayon = "1.8"
num_cpus = "1"

serde = { version="1", features=["derive"] }
serde_json = "1"

aws-config = "1"
aws-sdk-s3 = "1"

azure_storage = "0.18"
azure_storage_blobs = "0.18"

polars = { version="0.38", features=["lazy","parquet"] }
arrow = "50"

opencv = "0.88"

anyhow = "1"
thiserror = "1"

log = "0.4"
env_logger = "0.11"

[dev-dependencies]
cargo-nextest = "0.9"
EOF

############################################
# Rust lib
############################################

cat > rust-core/src/lib.rs <<'EOF'
// vim: set ts=2 sw=2 et:

use pyo3::prelude::*;

mod config;
mod runtime;
mod io;
mod dataset;
mod cv;
mod experiment;
mod parallel;
mod gpu;

#[pymodule]
fn deepsea_core(_py: Python, m: &PyModule) -> PyResult<()> {
  m.add_function(wrap_pyfunction!(runtime::system_info, m)?)?;
  Ok(())
}
EOF

############################################
# runtime
############################################

cat > rust-core/src/runtime.rs <<'EOF'
// vim: set ts=2 sw=2 et:

use pyo3::prelude::*;
use num_cpus;

#[pyfunction]
pub fn system_info() -> String {
  format!(
    "CPUs: {}, Max parallelism enabled",
    num_cpus::get()
  )
}
EOF

############################################
# config
############################################

cat > rust-core/src/config.rs <<'EOF'
// vim: set ts=2 sw=2 et:

use serde::{Deserialize, Serialize};

#[derive(Debug, Serialize, Deserialize)]
pub struct SystemConfig {
  pub workers: usize,
  pub gpu_enabled: bool,
}

impl Default for SystemConfig {
  fn default() -> Self {
    Self {
      workers: num_cpus::get(),
      gpu_enabled: true,
    }
  }
}
EOF

############################################
# parallel scheduler
############################################

cat > rust-core/src/parallel/scheduler.rs <<'EOF'
// vim: set ts=2 sw=2 et:

use rayon::prelude::*;

pub fn parallel_map<T: Send, R: Send, F>(data: Vec<T>, f: F) -> Vec<R>
where
  F: Fn(T) -> R + Send + Sync,
{
  data.into_par_iter().map(f).collect()
}
EOF

cat > rust-core/src/parallel/mod.rs <<'EOF'
// vim: set ts=2 sw=2 et:
pub mod scheduler;
EOF

