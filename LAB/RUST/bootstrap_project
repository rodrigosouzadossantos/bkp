############################################
# GitHub CI
############################################

cat > .github/workflows/ci.yml <<'EOF'
name: CI

on: [push]

jobs:
 build:

  runs-on: ubuntu-latest

  steps:

  - uses: actions/checkout@v4

  - uses: actions/setup-python@v5
    with:
      python-version: 3.11

  - uses: dtolnay/rust-toolchain@stable

  - run: pip install maturin pytest

  - run: maturin develop

  - run: pytest
EOF

