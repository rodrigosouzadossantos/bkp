#!/usr/bin/env bash
set -e
set -o pipefail

PROJECT=${1:-nautilus-ml}
echo "Bootstrapping Nautilus ML platform in $PROJECT ..."

########################################
# Helper functions for headers
########################################

create_header() {
  LANG=$1
  MODULE=$2
  COMPONENT=$3
  if [ "$LANG" = "rust" ]; then COMMENT="//"; else COMMENT="#"; fi
  cat <<EOF
$COMMENT vim: set ts=2 sw=2 et:
$COMMENT --------------------------------------------------
$COMMENT Project: Nautilus ML Platform
$COMMENT Module: $MODULE
$COMMENT Component: $COMPONENT
$COMMENT Inspired by Jules Verne's "Twenty Thousand Leagues Under the Sea"
$COMMENT License: Apache-2.0
$COMMENT --------------------------------------------------
EOF
}

create_file() {
  FILE=$1
  LANG=$2
  MODULE=$3
  COMPONENT=$4
  mkdir -p "$(dirname "$FILE")"
  create_header "$LANG" "$MODULE" "$COMPONENT" > "$FILE"
}

########################################
# Directory structure
########################################

mkdir -p $PROJECT/rust/{core,storage,dataset,cv,experiment,visualization,python-bindings}
mkdir -p $PROJECT/python/nautilus_ml
mkdir -p $PROJECT/tests
mkdir -p $PROJECT/scripts
mkdir -p $PROJECT/configs
mkdir -p $PROJECT/templates
mkdir -p $PROJECT/.github/workflows

########################################
# Header template
########################################

cat > $PROJECT/templates/header.template <<EOF
Project: Nautilus ML Platform
Inspired by Jules Verne's "Twenty Thousand Leagues Under the Sea"
Module: <MODULE>
Component: <COMPONENT>
Description:
High-performance Rust core for deep-sea computer vision pipelines.
Data Lineage: Arrow columnar datasets, zero-copy NumPy/Torch bridge
Experiment Tracking: MLFlow / W&B / DVC / LakeFS
Author: Nautilus AI Platform Engineering
License: Apache-2.0
EOF

########################################
# Rust workspace
########################################

cd $PROJECT/rust
cat > Cargo.toml <<EOF
[workspace]
members = [
 "core",
 "storage",
 "dataset",
 "cv",
 "experiment",
 "visualization",
 "python-bindings"
]
EOF

for crate in core storage dataset cv experiment visualization python-bindings; do
  cargo new $crate --lib
done

########################################
# Rust dependencies
########################################

# core
cd core
cargo add rayon tokio num_cpus serde serde_json anyhow thiserror log env_logger arrow numpy
cd ..

# storage
cd storage
cargo add aws-config aws-sdk-s3 azure_storage azure_storage_blobs tokio rayon
cd ..

# dataset
cd dataset
cargo add arrow polars numpy rayon tokio
cd ..

# cv
cd cv
cargo add opencv ndarray rayon tokio
cd ..

# experiment
cd experiment
cargo add reqwest serde_json tokio
cd ..

# visualization
cd visualization
cargo add pyo3 --features extension-module numpy arrow
cd ..

# python bindings
cd python-bindings
cargo add pyo3 --features extension-module numpy
cd ../..

########################################
# Python environment
########################################

uv venv
source .venv/bin/activate
uv init --name nautilus-ml --python 3.11

uv add numpy pandas pyarrow torch torchvision torchaudio tensorflow keras scikit-learn
uv add altair plotly mlflow wandb dvc[s3] dvc[azure] lakefs-client boto3 azure-storage-blob
uv add pytest ruff mypy maturin

