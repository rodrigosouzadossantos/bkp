use opencv::videoio;
use opencv::prelude::*;

pub fn read_video_frames(path: &str) -> opencv::Result<Vec<opencv::core::Mat>> {
    let mut cap = videoio::VideoCapture::from_file(path, videoio::CAP_ANY)?;
    let mut frames = vec![];
    let mut frame = opencv::core::Mat::default();
    while cap.read(&mut frame)? {
        frames.push(frame.clone());
    }
    Ok(frames)
}

#[cfg(test)]
mod tests {
    use super::*;
    #[test]
    fn test_video_read() {
        let res = read_video_frames("./Cargo.toml");
        assert!(res.is_ok());
    }
}
EOF

