use azure_storage::prelude::*;
use azure_storage_blobs::prelude::*;
use tokio;
use rayon::prelude::*;

pub async fn list_containers(account: &str, key: &str) -> Vec<String> {
    let storage = StorageAccountClient::new_access_key(account, key)
        .as_storage_client();
    let resp = storage.list_containers().execute().await.unwrap();
    resp.incomplete_vector.iter().map(|c| c.name.clone()).collect()
}

