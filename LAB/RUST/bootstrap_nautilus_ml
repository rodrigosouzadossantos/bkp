use aws_sdk_s3::{Client, Config, Region};
use aws_config::meta::region::RegionProviderChain;
use tokio_stream::StreamExt;
use rayon::prelude::*;

pub async fn list_buckets() -> Vec<String> {
    let region_provider = RegionProviderChain::default_provider().or_else("us-east-1");
    let config = aws_config::from_env().region(region_provider).load().await;
    let client = Client::new(&config);

    let resp = client.list_buckets().send().await.unwrap();
    let names = resp.buckets().unwrap_or(&[]).iter()
        .filter_map(|b| b.name.clone())
        .collect::<Vec<_>>();
    names
}

pub async fn list_objects(bucket: &str) -> Vec<String> {
    let region_provider = RegionProviderChain::default_provider().or_else("us-east-1");
    let config = aws_config::from_env().region(region_provider).load().await;
    let client = Client::new(&config);

    let resp = client.list_objects_v2().bucket(bucket).send().await.unwrap();
    let keys = resp.contents().unwrap_or(&[]).iter()
        .filter_map(|obj| obj.key.clone())
        .collect::<Vec<_>>();
    keys
}

pub fn parallel_download(keys: Vec<String>) {
    keys.par_iter().for_each(|k| {
        println!("Downloading: {}", k);
        // Insert actual S3 download code here
    });
}

#[cfg(test)]
mod tests {
  use super::*;
  #[tokio::test]
  async fn test_list_buckets() {
    let buckets = list_buckets().await;
    println!("Buckets: {:?}", buckets);
  }
}
EOF

